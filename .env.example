# ========================================
# FeetToPixels - Environment Variables
# ========================================
# Copy this file to .env.local and fill in your values

# Site URL
NEXT_PUBLIC_SITE_URL=https://feettopixels.com

# Admin Dashboard
ADMIN_PASSWORD=change-this-to-a-secure-password
ADMIN_SECRET=generate-a-random-32-character-string

# Vercel Blob (only if hosting on Vercel)
# BLOB_READ_WRITE_TOKEN=vercel_blob_xxxxxxxxxxxx
